# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Cursor / Claude Code metadata
.cursor/
.claude/

# vscode
.vscode/

# Payload CMS
/apps/cms/media
/apps/cms/payload-types.ts
/apps/cms/node_modules
/apps/cms/.next

# packages build output
/packages/*/dist

# Docker
docker-compose.override.yml

# Web
/apps/web/node_modules
/apps/web/.next