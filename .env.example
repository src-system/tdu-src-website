# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tdu_src
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tdu_src

# Payload CMS Configuration
PAYLOAD_SECRET=your-secret-key-here-change-this-in-production
# 未設定時は NEXT_PUBLIC_CMS_URL が serverURL に使われる（ローカルでは必ず実際のオリジンと一致させる）
# CMS_SERVER_URL=http://localhost:3001
CMS_PORT=3001

# Next.js Web Configuration
NEXT_PUBLIC_CMS_URL=http://localhost:3001
WEB_PORT=3000

# Environment
NODE_ENV=development
